---
// Gerado a partir de: index.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import '../styles/index.css';
---

<Base
  title="Juqy Beach House — Casamentos à beira-mar | Praia de Juqueí, São Sebastião"
  description="Tenha uma das paisagens mais deslumbrantes do litoral norte como cenário do seu casamento. Praia de Juqueí, São Sebastião. Destination wedding."
  ogImage="/images/og-index.jpg"
>
<!-- ===== HERO ===== -->
<header class="hero" id="top">
  <div class="hero-bg" data-parallax="0.25"><img src="https://media.dmove.com.br/clients/juqybeach/photos/hero.webp" alt="Cerimônia de casamento na praia de Juqueí ao pôr do sol" width="1920" height="1080" loading="eager" fetchpriority="high" /></div>
  <img src="https://media.dmove.com.br/clients/juqybeach/photos/juqy-logo.webp" alt="Juqy Beach House" class="hero-logo" loading="eager" />
  <div class="hero-inner">
    <p class="hero-sub reveal in">Praia de Juqueí&nbsp; · &nbsp;São Sebastião&nbsp; · &nbsp;Destination Wedding</p>
    <div class="hero-divider reveal in d1"></div>
    <h1 class="reveal in d2">O mar do litoral norte como cenário<br>do seu casamento pé na areia.</h1>
  </div>
  <div class="scroll-ind"><span class="line"></span></div>
</header>

<!-- ===== SOBRE ===== -->
<section id="sobre" class="pad">
  <div class="wrap center">
    <p class="eyebrow reveal">O Espaço</p>
    <h2 class="section-title center reveal d1">À beira-mar como você sempre sonhou.</h2>
    <p class="lead center reveal d2" style="margin-top:28px">Localizado em São Sebastião, na Praia de Juqueí, a Juqy Beach House oferece um cenário único para casamentos “pé na areia”, onde a natureza e a estrutura do espaço se unem para criar uma celebração inesquecível. Além do dia do casamento, os noivos e seus familiares também podem aproveitar a hospedagem no local, vivendo momentos especiais antes e depois da celebração.</p>
    <div class="sobre-grid reveal d1">
      <div class="figure s1"><img src="https://media.dmove.com.br/clients/juqybeach/photos/sobre1.webp" alt="Vista do mar em Juqueí" loading="lazy" /></div>
      <div class="figure s2"><img src="https://media.dmove.com.br/clients/juqybeach/photos/sobre2.webp" alt="Praia de Juqueí" loading="lazy" /></div>
      <div class="figure s3"><img src="https://media.dmove.com.br/clients/juqybeach/photos/sobre3.webp" alt="Natureza do espaço" loading="lazy" /></div>
      <div class="figure s4"><img src="https://media.dmove.com.br/clients/juqybeach/photos/sobre4.webp" alt="Detalhe do espaço" loading="lazy" /></div>
      <div class="figure s5"><img src="https://media.dmove.com.br/clients/juqybeach/photos/sobre5.webp" alt="Ambiente à beira-mar" loading="lazy" /></div>
      <div class="figure s6"><img src="https://media.dmove.com.br/clients/juqybeach/photos/sobre6.webp" alt="Estrutura da Juqy Beach House" loading="lazy" /></div>
      <div class="figure s7"><img src="https://media.dmove.com.br/clients/juqybeach/photos/sobre7.webp" alt="Vista da Juqy Beach House" loading="lazy" /></div>
    </div>
  </div>
</section>

<!-- ===== DIA DA NOIVA ===== -->
<section id="noiva" class="pad" style="background:var(--bg-soft)">
  <div class="wrap">
    <div class="band">
      <div class="band-text">
        <p class="eyebrow reveal">Dia da Noiva</p>
        <h2 class="section-title reveal d1">O seu dia começa onde o céu, o mar e a natureza se encontram em perfeita harmonia.</h2>
        <p class="lead reveal d2" style="margin-top:24px">Com acomodações confortáveis e uma vista deslumbrante para a praia, os noivos podem desacelerar e aproveitar cada instante que antecede o casamento. No dia da celebração, o ambiente se torna o cenário ideal para se prepararem com padrinhos e madrinhas, compartilhando momentos únicos antes da cerimônia.</p>
      </div>
      <div class="band-media reveal d1">
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva4.webp" alt="Preparação da noiva" style="width:100%;aspect-ratio:4/5;object-fit:cover" loading="lazy" /></div>
      </div>
    </div>
  </div>
  <div class="wrap" style="margin-top:56px">
    <div class="carousel reveal">
      <button class="car-btn prev" aria-label="Anterior"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg></button>
      <div class="car-track portrait">
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva13.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva12.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva11.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva10.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva9.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva8.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva7.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva6.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva5.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva4.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva3.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva2.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/noiva1.webp" alt="" loading="lazy" /></div>
      </div>
      <button class="car-btn next" aria-label="Próximo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg></button>
    </div>
  </div>
</section>

<!-- ===== CERIMÔNIA ===== -->
<section id="cerimonia" class="pad">
  <div class="wrap">
    <div class="center" style="max-width:760px;margin-inline:auto">
      <p class="eyebrow reveal">A Cerimônia</p>
      <h2 class="section-title center reveal d1" style="max-width:none;white-space:nowrap;font-size:clamp(1.2rem,6vw,3rem)">O cenário dos seus votos.</h2>
      <p class="lead center reveal d2" style="margin-top:24px">Contamos com dois espaços para cerimônia, garantindo mais tranquilidade aos noivos diante de imprevistos e oferecendo diferentes possibilidades de configuração para o evento.</p>
    </div>

    <div class="cer-block" style="margin-top:70px">
      <div class="block-head reveal"><h3>Cerimônia pé na areia</h3></div>
      <div class="trio quad reveal d1">
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/areia1.webp" alt="Cerimônia pé na areia" loading="lazy" /></div>
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/areia4.webp" alt="Cerimônia pé na areia" loading="lazy" /></div>
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/areia3.webp" alt="Cerimônia pé na areia" loading="lazy" /></div>
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/areia2.webp" alt="Cerimônia pé na areia" loading="lazy" /></div>
      </div>
    </div>

    <div class="cer-block">
      <div class="block-head reveal"><h3>Cerimônia no deck</h3></div>
      <div class="trio reveal d1">
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/deck1.webp" alt="Cerimônia no deck" loading="lazy" /></div>
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/deck3.webp" alt="Cerimônia no deck" loading="lazy" /></div>
        <div class="figure"><img src="https://media.dmove.com.br/clients/juqybeach/photos/deck2.webp" alt="Cerimônia no deck" loading="lazy" /></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== ESTRUTURA ===== -->
<section id="estrutura" class="pad" style="background:#e8e1d5">
  <div class="wrap center">
    <p class="eyebrow reveal">A Estrutura</p>
    <h2 class="section-title center reveal d1">Um ambiente desenhado para acolher seu casamento.</h2>
    <p class="lead center reveal d2" style="margin-top:24px">Aqui cada detalhe cabe na sua história.</p>
    <div class="sobre-grid reveal d1">
      <div class="figure e1"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura2.webp" alt="Lounge da Juqy Beach House com sofás e decoração" loading="lazy" /></div>
      <div class="figure e2"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura9.webp" alt="Lounge com luminárias de vime" loading="lazy" /></div>
      <div class="figure e3"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura5.webp" alt="Suíte dos noivos" loading="lazy" /></div>
      <div class="figure e4"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura6.webp" alt="Jardim e passarela de madeira" loading="lazy" /></div>
      <div class="figure e5"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura3.webp" alt="Mesa de jantar sob o pergolado" loading="lazy" /></div>
      <div class="figure e6"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura4.webp" alt="Deck de jantar com vista para o mar" loading="lazy" /></div>
      <div class="figure e7"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura11.webp" alt="Vista do deck e da praia" loading="lazy" /></div>
      <div class="figure e8"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura1.webp" alt="Praia de Juqueí ao entardecer" loading="lazy" /></div>
      <div class="figure e9"><img src="https://media.dmove.com.br/clients/juqybeach/photos/estrutura10.webp" alt="Lounge à beira-mar" loading="lazy" /></div>
    </div>
  </div>
</section>

<!-- ===== RECEPÇÃO ===== -->
<section id="recepcao" class="pad" style="background:var(--bg-soft)">
  <div class="wrap center">
    <p class="eyebrow reveal">A Recepção</p>
    <h2 class="section-title center reveal d1">Momento de celebrar ao lado de quem você ama.</h2>
    <p class="lead center reveal d2" style="margin-top:24px">Um espaço descontraído e envolvido pela natureza, onde a leveza e o bem-estar se unem a uma estética sofisticada, perfeito para receber seus convidados.</p>
  </div>
  <div class="wrap" style="margin-top:52px">
    <div class="carousel reveal">
      <button class="car-btn prev" aria-label="Anterior"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg></button>
      <div class="car-track land">
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao9.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao8.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao7.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao6.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao5.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao4.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao3.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao2.webp" alt="" loading="lazy" /></div>
        <div class="slide"><img src="https://media.dmove.com.br/clients/juqybeach/photos/recepcao1.webp" alt="" loading="lazy" /></div>
      </div>
      <button class="car-btn next" aria-label="Próximo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg></button>
    </div>
  </div>
</section>

<!-- ===== FEEDBACKS ===== -->
<section class="feedbacks pad">
  <div class="fb-bg" data-parallax="0.18"><img src="https://media.dmove.com.br/clients/juqybeach/photos/feedbacks.webp" alt="Casamento na Juqy Beach House" loading="lazy" /></div>
  <div class="wrap fb-inner">
    <p class="eyebrow center reveal" style="color:var(--sand)">Quem celebrou aqui</p>
    <div class="fb-quote reveal d1" id="fbQuote">
      <div class="fb-item active">
        <span class="fb-mark">“</span>
        <p class="fb-text">A Juqy foi o lugar que eu e meu marido decidimos nos casar em Novembro de 2025 e foi a melhor escolha que poderíamos ter feito. Tivemos convidados hospedados na casa desde sexta até segunda de manhã, e a experiência foi realmente muito especial. O dia do evento foi incrível. Recomendo muito o espaço e toda a equipe, sempre pronta para nos ajudar.</p>
        <p class="fb-author">Karima Ruhmann</p>
      </div>
      <div class="fb-item">
        <span class="fb-mark">“</span>
        <p class="fb-text">Sou celebrante social de casamentos. Realizei aqui uma das mais belas celebrações das centenas que já fiz. Um lugar lindo, bem preparado e ideal para suas celebrações.</p>
        <p class="fb-author">Sylvio Montenegro</p>
      </div>
      <div class="fb-item">
        <span class="fb-mark">“</span>
        <p class="fb-text">Um dos melhores lugares de casamento na praia! Espaço lindo, vista maravilhosa, sempre nos recebem super bem. A Lu é uma pessoa muito acolhedora também. Super recomendo para noivos que querem casar na praia a Juqy.</p>
        <p class="fb-author">Paulo Rauch</p>
      </div>
      <div class="fb-item">
        <span class="fb-mark">“</span>
        <p class="fb-text">Que espaço maravilhoso! A Juqy foi, com certeza, uma escolha muito acertada para o nosso casamento. A infraestrutura, a localização e a energia do espaço são incríveis. Criamos memórias pra sempre atreladas a esse lugar, com suas árvores maravilhosas e vista da praia.</p>
        <p class="fb-author">Fabiana Azuma</p>
      </div>
      <div class="fb-item">
        <span class="fb-mark">“</span>
        <p class="fb-text">Máxima organização dos quartos e cozinha, caseiro sempre à disposição. Nós amamos TUDO! O lugar já carrega todo um charme e deixou o dia mais especial ainda — todos os convidados ficaram encantados. Não poderíamos ter escolhido melhor, que energia.</p>
        <p class="fb-author">Giovanna e Thiago</p>
      </div>
      <div class="fb-item">
        <span class="fb-mark">“</span>
        <p class="fb-text">Deu tudo certo! Recebemos muitos elogios do espaço e, claro, da festa, que estava incrível. Muito obrigado por nos receber tão bem!</p>
        <p class="fb-author">Rubi e Rodrigo</p>
      </div>
    </div>
    <div class="fb-dots" id="fbDots"></div>
  </div>
</section>

<!-- ===== INFRAESTRUTURA ===== -->
<section id="infra" class="pad">
  <div class="wrap center">
    <p class="eyebrow reveal">Infraestrutura</p>
    <h2 class="section-title center reveal d1">Exclusividades que fazem parte da experiência Juqy.</h2>
    <p class="lead center reveal d2" style="margin-top:24px">Conheça alguns dos diferenciais que tornam a Juqy Beach House um cenário único para celebrar o seu casamento em Maresias.</p>
  </div>
  <div class="wrap">
    <div class="infra-grid reveal">
      <div class="infra-cell">
        <svg viewBox="0 0 24 24"><path d="M2 20h20M4 20v-8l8-6 8 6v8M9 20v-5h6v5"/><path d="M2 12c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/></svg>
        <h3>Cerimônia e festa integradas frente ao mar</h3>
      </div>
      <div class="infra-cell">
        <svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3"/><circle cx="17" cy="9" r="2.4"/><path d="M3 20c0-3 2.7-5 6-5s6 2 6 5M15 20c0-2.4 1-4.2 3-4.7"/></svg>
        <h3>Capacidade para até 250 convidados</h3>
      </div>
      <div class="infra-cell">
        <svg viewBox="0 0 24 24"><path d="M4 3v7a3 3 0 006 0V3M7 3v18M14 3c-1.5 1-2 3-2 5s.5 3 2 3v10"/></svg>
        <h3>Cozinha equipada + área de apoio para o buffet</h3>
      </div>
      <div class="infra-cell">
        <svg viewBox="0 0 24 24"><path d="M3 11l9-7 9 7M5 10v10h14V10M9 20v-6h6v6"/></svg>
        <h3>Suíte exclusiva para os noivos</h3>
      </div>
      <div class="infra-cell">
        <svg viewBox="0 0 24 24"><path d="M12 21s-7-6.2-7-11a7 7 0 0114 0c0 4.8-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
        <h3>Localização privilegiada e fácil acesso</h3>
      </div>
      <div class="infra-cell">
        <svg viewBox="0 0 24 24"><path d="M3 21V8l9-5 9 5v13M3 21h18M8 21v-5h3v5M14 11h3M14 15h3"/></svg>
        <h3>Hospedagem para até 15 pessoas</h3>
      </div>
    </div>
  </div>
</section>

<!-- ===== GALERIA ===== -->
<section id="galeria" class="pad" style="background:var(--bg-soft)">
  <div class="wrap center">
    <p class="eyebrow reveal">Galeria</p>
    <h2 class="section-title center reveal d1">Cada sorriso registrado conta um pouco da experiência que proporcionamos.</h2>
    <p class="lead center reveal d2" style="margin-top:24px">Celebre o seu casamento pé na areia em Juqueí!</p>
  </div>
  <div class="wrap">
    <div class="gal reveal" id="gal">
      <div class="figure g1"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria7.webp" alt="Casamento na Juqy" loading="lazy" /></div>
      <div class="figure g2"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria6.webp" alt="" loading="lazy" /></div>
      <div class="figure g3"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria1.webp" alt="" loading="lazy" /></div>
      <div class="figure g4"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria2.webp" alt="" loading="lazy" /></div>
      <div class="figure g5"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria8.webp" alt="" loading="lazy" /></div>
      <div class="figure g6"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria10.webp" alt="" loading="lazy" /></div>
      <div class="figure g7"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria3.webp" alt="" loading="lazy" /></div>
      <div class="figure g8"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria9.webp" alt="" loading="lazy" /></div>
      <div class="figure g9"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria4.webp" alt="" loading="lazy" /></div>
      <div class="figure g10"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria5.webp" alt="" loading="lazy" /></div>
      <div class="figure g11"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria11.webp" alt="" loading="lazy" /></div>
      <div class="figure g12"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria12.webp" alt="" loading="lazy" /></div>
      <div class="figure g13"><img src="https://media.dmove.com.br/clients/juqybeach/photos/galeria13.webp" alt="" loading="lazy" /></div>
    </div>
  </div>
</section>

<!-- ===== FORMULÁRIO ===== -->
<section id="contato" class="form-sec pad">
  <div class="wrap form-card">
    <div class="center">
      <p class="eyebrow reveal">Contato</p>
      <h2 class="section-title center reveal d1">Estamos prontos para fazer parte da sua história.</h2>
      <p class="lead center reveal d2" style="margin-top:20px">Preencha o formulário para receber nosso contato.</p>
    </div>
    <form
      id="leadForm"
      class="reveal"
      novalidate
      data-form-id="lead-form"
      data-project={config.project_slug}
      data-submit-url={config.forms['lead-form'].webhooks[0]}
      data-redirect={config.forms['lead-form'].redirect_on_success}
      data-grid-id="leadFormGrid"
      data-success-id="formSuccess"
    >
      <div class="hp-field" aria-hidden="true">
        <label for="lead-form_website">Deixe este campo em branco</label>
        <input type="text" id="lead-form_website" name="website" tabindex="-1" autocomplete="off" />
      </div>
      <div id="leadFormGrid">
        <div class="fgrid">
          <div class="field"><label for="Nome">Nome</label><input id="Nome" name="Nome" type="text" required /></div>
          <div class="field"><label for="WhatsApp">WhatsApp</label><input id="WhatsApp" name="WhatsApp" type="text" required data-mask="phone" /></div>
        </div>
        <div class="fgrid" style="margin-top:22px">
          <div class="field"><label for="E-mail">E-mail</label><input id="E-mail" name="E-mail" type="email" required /></div>
          <div class="field"><label for="data-evento">Data do evento</label><input id="data-evento" name="Data do evento" type="text" placeholder="dd/mm/aaaa" data-datepicker /></div>
        </div>
        <div class="fgrid" style="margin-top:22px">
